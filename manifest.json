{
  "manifest_version": 3,
  "name": "Trish - Voice Web Assistant",
  "version": "0.1.0",
  "description": "Voice-controlled web assistant for blind and low-vision users: reads pages, answers questions about content, fills forms, and takes actions by voice.",
  "minimum_chrome_version": "116",
  "permissions": ["storage", "tabs", "scripting", "sidePanel", "activeTab", "debugger"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "options_page": "options/options.html",
  "action": {
    "default_title": "Open Trish voice assistant (Alt+V)"
  },
  "commands": {
    "open-panel": {
      "suggested_key": { "default": "Alt+V" },
      "description": "Open the Trish side panel"
    },
    "toggle-voice": {
      "suggested_key": { "default": "Alt+Shift+V" },
      "description": "Start or stop the voice session"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
